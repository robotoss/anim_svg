# Build / tool outputs.
build/
.dart_tool/
pubspec.lock
*.log

# Prebuilt native artifacts — fetched from GitHub Releases by
# tool/download_prebuilt.sh at pod install / gradle build time.
ios/Frameworks/
android/src/main/jniLibs/

# Rust build output.
native/anim_svg_core/target/

# Example app's build artifacts, platform wrappers, and test-only code.
# The Dart source (example/lib, example/pubspec.yaml, example/assets) still
# ships so pub.dev can render the Example tab.
example/ios/
example/android/
example/.dart_tool/
example/build/
example/pubspec.lock
example/integration_test/

# Vendored thorvg.flutter fork — published separately to pub.dev as
# `thorvg_plus` (consumers get it from pub.dev). Anchor the pattern so it
# applies only to the anim_svg root package. An unanchored `thorvg.flutter/`
# would propagate into the child package publish and hide everything there.
/thorvg.flutter/

# Tests and fixtures — dev-only.
test/

# Internal documentation workspace.
brain/

# IDE / editor state.
.idea/
.vscode/
*.iml

# macOS / misc.
.DS_Store
